# ────────────────────────────────────────────────────────────────────
# ZOOM MOBILES — environment variables
# ────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values from your
# Supabase project dashboard: https://app.supabase.com → Project → Settings → API
# ────────────────────────────────────────────────────────────────────

# Supabase — public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase — service role (SERVER ONLY — never expose to browser!)
# Used by admin actions: create customer, set their password, etc.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for redirects & meta tags)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
